<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".usescase.tutorial.TutorialActivity">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/continueButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="¡Entendido!"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/continueButton"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="¡Bienvenido/a!"
                android:textAppearance="?attr/textAppearanceHeadlineLarge" />

            <TextView
                android:id="@+id/subtitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Esta app te ayuda a saber qué aditivos alimentarios son aptos para veganos."
                android:textAlignment="center"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <TextView
                android:id="@+id/searchHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="🔍  Busca por nombre o número"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <TextView
                android:id="@+id/colorsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="🎨  Identifica el origen por su color"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <LinearLayout
                android:id="@+id/colorLegendLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟢  Verde: Origen Vegano" android:drawablePadding="8dp" android:gravity="center_vertical" android:drawableStart="@drawable/vegan_icon_ok" android:textAppearance="?attr/textAppearanceBodyLarge"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="🟡  Amarillo: Origen Dudoso" android:drawablePadding="8dp" android:gravity="center_vertical" android:drawableStart="@drawable/question_icon" android:textAppearance="?attr/textAppearanceBodyLarge"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="🔴  Rojo: Origen No Vegano" android:drawablePadding="8dp" android:gravity="center_vertical" android:drawableStart="@drawable/skull_icon" android:textAppearance="?attr/textAppearanceBodyLarge"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>